# .env.example
# 변경이력: v1.0.0 | 2026-04-07 | [Implementer] | 최초 생성

# ===== SIP ACL (FS-1: mod_acl) =====
# Restrict inbound SIP INVITE to PBX/SBC IPs only
# Dev default: 0.0.0.0/0 (allow all). Production: MUST set exact PBX IPs!
# Example: PBX_ACL_IP1=10.10.1.100/32
PBX_ACL_IP1=0.0.0.0/0
PBX_ACL_IP2=0.0.0.0/0

# ===== SIP =====
SIP_PORT=5060
SIP_TLS_PORT=5061
SIP_TLS_ONLY=false
SIP_TLS_CERT_DIR=/etc/freeswitch/tls
SRTP_MODE=optional

# ===== NAT (S-04) =====
# Same network / dedicated line: auto-nat works fine
# Behind NAT / firewall: MUST set public IP to prevent one-way audio!
#   Find your public IP: curl ifconfig.me
# Example: EXTERNAL_RTP_IP=203.0.113.10
EXTERNAL_RTP_IP=auto-nat
EXTERNAL_SIP_IP=auto-nat
STUN_ENABLED=true

# ===== Session =====
# P-13: false recommended unless PBX explicitly requires 100rel
PRACK_ENABLED=false
SESSION_TIMER_ENABLED=true
# T-22: Default 1800 (30min) matches vars.xml. Set 0 to disable forced hangup.
SESSION_TIMEOUT=1800
MIN_SE=90
ANSWER_DELAY_MS=200

# ===== RTP =====
# T-23: Default 16584 matches docker-compose/vars.xml (200 ports = 100 concurrent calls).
# Increase to 32768 (16384 ports) only if you need 8000+ concurrent calls.
RTP_PORT_MIN=16384
RTP_PORT_MAX=16584

# ===== Jitter Buffer (P-10) =====
# Dedicated line/VPN (low jitter): 40:20:100
# Internet (high jitter):          100:60:300
# Default (moderate):              60:20:200
JB_INIT_MS=60
JB_MIN_MS=20
JB_MAX_MS=200

# ===== PBX (Primary) =====
PBX_HOST=
PBX_USERNAME=
PBX_PASSWORD=
PBX_REGISTER=false

# ===== PBX Standby (P-11: failover) =====
PBX_STANDBY_HOST=
PBX_STANDBY_USERNAME=
PBX_STANDBY_PASSWORD=
PBX_STANDBY_REGISTER=false

# ===== ESL =====
ESL_HOST=127.0.0.1
ESL_PORT=8021
# ===== IVR (R-07) =====
# DTMF '0' → 상담원 전환 대상 (예: 1000@pbx, agent_queue)
# 비어있으면 전환 기능 비활성화 (로그 경고만)
IVR_TRANSFER_TARGET=

# ===== Codec (P-05) =====
# PBX compatibility: G.711 first (default). For Opus-capable PBX: opus@48000h@20i,G722,PCMU,PCMA
INBOUND_CODEC_PREFS=PCMU@8000h@20i,PCMA@8000h@20i,G722@16000h@20i,opus@48000h@20i
OUTBOUND_CODEC_PREFS=PCMU@8000h@20i,PCMA@8000h@20i,G722@16000h@20i,opus@48000h@20i

# ===== ESL =====
# MUST change from default — generate with: openssl rand -hex 16
ESL_PASSWORD=<your-strong-esl-password>

# ===== HTTP API =====
HTTP_PORT=8080
# MUST change — generate with: openssl rand -hex 32
ADMIN_API_KEY=<generate-with-openssl-rand-hex-32>
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# ===== Session =====
MAX_SESSIONS=100

# ===== AI Engine =====
AI_GRPC_ADDR=127.0.0.1:50051
AI_GRPC_TLS=false

# ===== Bridge =====
BRIDGE_HOST=127.0.0.1
BRIDGE_WS_PORT=8090
BRIDGE_INTERNAL_PORT=8091

# ===== VAD =====
ONNX_MODEL_PATH=/models/silero_vad.onnx

# ===== gRPC Retry =====
GRPC_MAX_RETRIES=5
GRPC_MAX_BACKOFF_MS=4000
# T-28: 2h default (prevents zombie gRPC streams). Max = longest expected call * 1.5
GRPC_STREAM_DEADLINE_SECS=7200

# ===== Recording =====
RECORDING_ENABLE=false
RECORDING_DIR=/recordings
RECORDING_MAX_DAYS=30
RECORDING_MAX_MB=1024

# ===== Runtime =====
RUNTIME_PROFILE=dev
LOG_LEVEL=info
